
import requests
from bs4 import BeautifulSoup
import re
import torch
import torch.nn as nn
import torch.optim as optim
from torch.utils.data import Dataset, DataLoader
import random

# 1. Extract text from Wikipedia
def get_wikipedia_text(url):
    headers = {"User-Agent": "Mozilla/5.0 (compatible; MyScript/1.0)"}
    response = requests.get(url, headers=headers)
    soup = BeautifulSoup(response.text, "html.parser")
    paragraphs = soup.find_all("p")
    text = " ".join([p.get_text() for p in paragraphs])
    text = re.sub(r'\s+', ' ', text)  # clean whitespace
    return text

url = "https://en.wikipedia.org/wiki/Transformer_(machine_learning_model)"
raw_text = get_wikipedia_text(url)

# 2. Tokenize and build vocabulary
tokens = raw_text.lower().split()
vocab = {"<pad>":0, "<unk>":1}
for tok in tokens:
    if tok not in vocab:
        vocab[tok] = len(vocab)
id2word = {i:w for w,i in vocab.items()}

# 3. Generate (center, context) pairs for Skip-gram
def generate_skipgram_pairs(tokens, window_size=2):
    pairs = []
    for i, center in enumerate(tokens):
        for j in range(max(0, i-window_size), min(len(tokens), i+window_size+1)):
            if i != j:
                pairs.append((center, tokens[j]))
    return pairs

pairs = generate_skipgram_pairs(tokens, window_size=2)

# 4. Dataset for Skip-gram
class SkipGramDataset(Dataset):
    def __init__(self, pairs, vocab, num_negatives=5):
        self.pairs = pairs
        self.vocab = vocab
        self.num_negatives = num_negatives
        self.word_ids = list(vocab.values())
    def __len__(self):
        return len(self.pairs)
    def __getitem__(self, idx):
        center, context = self.pairs[idx]
        center_id = self.vocab.get(center, self.vocab["<unk>"])
        context_id = self.vocab.get(context, self.vocab["<unk>"])
        # Sample negatives
        negatives = random.sample(self.word_ids, self.num_negatives)
        return torch.tensor(center_id), torch.tensor(context_id), torch.tensor(negatives)

dataset = SkipGramDataset(pairs, vocab)
loader = DataLoader(dataset, batch_size=64, shuffle=True)

# 5. Skip-gram Embedding Model
class SkipGramModel(nn.Module):
    def __init__(self, vocab_size, embed_dim):

        super(SkipGramModel, self).__init__()
        self.center_emb = nn.Embedding(vocab_size, embed_dim)
        self.context_emb = nn.Embedding(vocab_size, embed_dim)

    def forward(self, center, context, negatives):
        center_vec = self.center_emb(center)          # (batch, embed_dim)
        context_vec = self.context_emb(context)       # (batch, embed_dim)
        neg_vecs = self.context_emb(negatives)        # (batch, num_neg, embed_dim)

        # Positive score
        pos_score = torch.sum(center_vec * context_vec, dim=-1)
        pos_loss = torch.log(torch.sigmoid(pos_score + 1e-10))

        # Negative score
        neg_score = torch.bmm(neg_vecs, center_vec.unsqueeze(2)).squeeze()
        neg_loss = torch.log(torch.sigmoid(-neg_score + 1e-10)).sum(dim=-1)

        loss = -(pos_loss + neg_loss).mean()
        return loss

# 6. Training loop
embed_dim = 128
model = SkipGramModel(len(vocab), embed_dim)
optimizer = optim.Adam(model.parameters(), lr=0.001)

for epoch in range(3):
    total_loss = 0
    for center, context, negatives in loader:
        optimizer.zero_grad()
        loss = model(center, context, negatives)
        loss.backward()
        optimizer.step()
        total_loss += loss.item()
    print(f"Epoch {epoch+1}, Loss: {total_loss:.4f}")

# 7. Inspect learned embedding
word = "transformer"
word_id = vocab.get(word, vocab["<unk>"])
embedding_vector = model.center_emb(torch.tensor([word_id]))
print(f"Embedding for '{word}':\n", embedding_vector.detach().numpy())
