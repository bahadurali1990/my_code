# Full Characters based tokenization

class chars_tokenization:

    def __init__(self,text : str):

        self.vocab = sorted(set(text))

        self.char2id = {ch:id for id,ch in enumerate(self.vocab)}

        self.id2char = {id:ch for id,ch in enumerate(self.vocab)}

    def show_vocab(self):

        print(self.vocab)

        print(self.char2id)
        
        print(self.id2char)

    
    def tokenize(self,input):
        
        token_list = [ self.char2id[ch] for ch in input if  ch in self.vocab]

        return token_list

    def detokenize(self,input):

        character_list = [self.id2char[idx] for idx in input]

        return character_list

text = "The quick brown fox jumps over the lazy dog"

my_tokenizers = chars_tokenization(text)

my_tokenizers.show_vocab()

input = 'Char'

output = my_tokenizers.tokenize(input)

print(output)
