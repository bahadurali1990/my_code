import random
import torch
import torch.nn as nn
from torch.utils.data import Dataset, DataLoader

import requests
from bs4 import BeautifulSoup

# --- Fetch Wikipedia text ---
url = "https://en.wikipedia.org/wiki/India"
header = {"User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64)"}

def fetch_data(url:str, header:dict):
    try:
        response = requests.get(url, headers=header)
        soup = BeautifulSoup(response.text, "html.parser")
        paragraphs = soup.find_all("p")
        text = " ".join([p.get_text() for p in paragraphs])
        return text
    except:
        print("Something went wrong with the server")

final_text = fetch_data(url, header)

# --- Tokenization ---
tokens = final_text.lower().split()
vocab = {'<pad>':0, '<unk>':1}
for token in tokens:
    if token not in vocab:
        vocab[token] = len(vocab)

id2word = {id:word for word,id in vocab.items()}

# --- Skip-gram pair generation ---
def generate_skip_gram(tokens, window_size=2):
    pairs = []
    for i, center in enumerate(tokens):
        for j in range(max(0, i-window_size), min(len(tokens), i+window_size+1)):
            if i != j:
                pairs.append((center, tokens[j]))
    return pairs

pairs = generate_skip_gram(tokens, window_size=1)

# --- Dataset ---
class SkipGramDataset(Dataset):
    def __init__(self, pairs, vocab, num_negatives=5):
        self.pairs = pairs
        self.vocab = vocab
        self.num_negatives = num_negatives
        self.word_ids = list(vocab.values())

    def __len__(self):
        return len(self.pairs)

    def __getitem__(self, idx):
        center, context = self.pairs[idx]
        center_id  = self.vocab.get(center, self.vocab["<unk>"])
        context_id = self.vocab.get(context, self.vocab["<unk>"])
        negatives = random.sample(self.word_ids, self.num_negatives)
        return torch.tensor(center_id), torch.tensor(context_id), torch.tensor(negatives)

dataset = SkipGramDataset(pairs, vocab)
loader = DataLoader(dataset, batch_size=16, shuffle=True)

# --- Model ---
class SkipGramModel2(nn.Module):
    def __init__(self, vocab_size, embed_dim):
        super(SkipGramModel2, self).__init__()
        self.center_embedd = nn.Embedding(vocab_size, embed_dim)
        self.context_embedd = nn.Embedding(vocab_size, embed_dim)

    def forward(self, center, context, negatives):
        center_vec  = self.center_embedd(center)
        context_vec = self.context_embedd(context)
        neg_vector  = self.context_embedd(negatives)

        # positive score
        pos_score = torch.sum(center_vec * context_vec, dim=-1)
        pos_loss  = torch.log(torch.sigmoid(pos_score + 1e-10))

        # negative score
        neg_score = torch.bmm(neg_vector, center_vec.unsqueeze(2)).squeeze()
        neg_loss  = torch.log(torch.sigmoid(-neg_score + 1e-10)).sum(dim=-1)

        loss = -(pos_loss + neg_loss).mean()
        return loss

# --- Training loop ---
embed_dim = 128
model = SkipGramModel2(len(vocab), embed_dim)
from torch import optim
optimizer = optim.Adam(model.parameters(), lr=0.001)

for epoch in range(10):
    total_loss = 0
    for center, context, negatives in loader:
        optimizer.zero_grad()
        loss = model(center, context, negatives)
        loss.backward()   # fixed typo
        optimizer.step()
        total_loss += loss.item()
    avg_loss = total_loss / len(loader)
    print(f"Epoch {epoch+1}, Average Loss: {avg_loss:.4f}")

# --- Inspect embeddings ---
# After training, you can access the learned embeddings:
word_embeddings = model.center_embedd.weight.data

# Example: get embedding for the word "india"
word_id = vocab.get("india", vocab["<unk>"])
india_embedding = word_embeddings[word_id]
